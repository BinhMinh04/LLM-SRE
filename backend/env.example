# Copy to infra/.env and fill in. Never commit the real .env (see .gitignore).
#   cp infra/env.example infra/.env

# --- Database ---
POSTGRES_DB=iim
POSTGRES_USER=iim
DB_PASSWORD=change-me
# For running the backend outside compose (host access):
# DATABASE_URL=postgresql+asyncpg://iim:change-me@localhost:5432/iim

# --- LLM provider (decision 0016): bedrock | deepseek ---
LLM_PROVIDER=bedrock
MAX_ROUNDS=2
CACHE_TTL_SECONDS=1800

# Bedrock (Claude) — default; only hard AWS dependency
AWS_REGION=ap-southeast-1
MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0
FAST_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0

# DeepSeek (OpenAI-compatible) — for local testing without AWS
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat

# --- Embedding provider (decision 0016): titan | jina ---
# One database serves one embedding dimension; changing it needs a schema resize (migration 0002).
EMBEDDING_PROVIDER=titan
EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
EMBEDDING_DIM=1024
# Jina (jina-embeddings-v3 = 768-dim):
# EMBEDDING_PROVIDER=jina
# EMBEDDING_MODEL=jina-embeddings-v3
# EMBEDDING_DIM=768
# JINA_API_KEY=

# --- Auth (M6) ---
# JWT_SECRET=
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=

# --- Azure DevOps ticketing (stretch) ---
# AZDO_ORG=
# AZDO_PROJECT=
# AZDO_PAT=
