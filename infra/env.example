# Copy to infra/.env and fill in. Never commit the real .env (see .gitignore).
#   cp infra/env.example infra/.env

# --- Database ---
POSTGRES_DB=iim
POSTGRES_USER=iim
DB_PASSWORD=change-me
# For running the backend outside compose (host access):
# DATABASE_URL=postgresql+asyncpg://iim:change-me@localhost:5432/iim

# --- AWS Bedrock (only hard AWS dependency) ---
AWS_REGION=ap-southeast-1
MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0
FAST_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0
EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
MAX_ROUNDS=2
CACHE_TTL_SECONDS=1800

# --- Auth (M6) ---
# JWT_SECRET=
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=

# --- Azure DevOps ticketing (stretch) ---
# AZDO_ORG=
# AZDO_PROJECT=
# AZDO_PAT=
